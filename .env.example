# ----------------------------------------------------------------
# compose で参照される環境変数のデフォルト値
# 個人の上書きは .env に書く(.env は git 管理外)
# ----------------------------------------------------------------

# 公開ポート(ホストで衝突したら変える)
APP_PORT=8080
# ホスト常駐の MySQL(3306)との衝突を避けるため 13306 を既定にする
DB_PORT=13306
REDIS_PORT=6379
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
NEXT_PORT=3000
DB_PASSWORD=

# Linux 環境で uid/gid を合わせたい場合(macOS では空のままで OK)
UID=1000
GID=1000
